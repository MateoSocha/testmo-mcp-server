{
  "name": "testmo-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Model Context Protocol (MCP) server for the Testmo REST API — projects, test cases, folders, automation runs, milestones, users and more.",
  "main": "dist/server.js",
  "bin": {
    "testmo-mcp-server": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "npm run build && vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testmo",
    "testing",
    "qa",
    "test-management",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MateoSocha/testmo-mcp-server"
  },
  "homepage": "https://github.com/MateoSocha/testmo-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/MateoSocha/testmo-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
